---
import DocLayout from '../../layouts/DocLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  const order = ['Players', 'Contributors', 'Cross-referencing', 'Reference'];
  const map = new Map<string, { title: string; slug: string }[]>();
  for (const d of [...docs].sort((a, b) => a.data.order - b.data.order)) {
    const g = d.data.group;
    if (!map.has(g)) map.set(g, []);
    map.get(g)!.push({ title: d.data.title, slug: d.id });
  }
  const groups = order.filter((g) => map.has(g)).map((name) => ({ name, items: map.get(name)! }));
  return docs.map((d) => ({ params: { slug: d.id }, props: { doc: d, groups } }));
}

const { doc, groups } = Astro.props;
const { Content, headings } = await render(doc);
---
<DocLayout title={doc.data.title} group={doc.data.group} current={doc.id}
  groups={groups} headings={headings}>
  <Content />
</DocLayout>
