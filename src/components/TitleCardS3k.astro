---
// Sonic 3 & Knuckles title card (faithful to the engine's Sonic3kTitleCardManager /
// ObjArray_TtlCard): a red banner drops from the top, the zone name + "ZONE" + act
// slide in from the right (16 px/frame). Held, no exit. Andes (S3 cutscene font) for
// the text. CSS keyframes (reduced-motion-safe via the global tokens.css rule).
import OpenggfWordmark from './OpenggfWordmark.astro';
interface Props { version: { label: string; isPre: boolean } | null; }
const { version } = Astro.props;
---
<section class="s3k" data-hero="s3k" aria-label="OpenGGF — Open-Source Sonic Engine">
  <div class="s3k-banner"></div>
  <div class="s3k-wordmark"><OpenggfWordmark /></div>

  <div class="s3k-row">
    <span class="s3k-zone">ZONE</span>
    {version && <span class="s3k-ver"><i>Latest Version</i><b>{version.label}</b></span>}
  </div>

  <p class="s3k-tagline">Open-Source Sonic Engine</p>
  <div class="s3k-ctas">
    <a class="s3k-btn p" href="/#download">⬇ Download</a>
    <a class="s3k-btn s" href="/docs">Read the docs</a>
  </div>
</section>

<style>
  .s3k { position: relative; width: 100%; height: clamp(480px, 84vh, 820px);
    overflow: hidden; background: var(--ogf-blue); isolation: isolate; }

  /* red banner drops from the top, holds across the upper-middle */
  .s3k-banner {
    position: absolute; left: 0; right: 0; top: 22%; height: 30%;
    background: var(--ogf-red);
    border-top: 5px solid var(--ogf-ink); border-bottom: 5px solid var(--ogf-ink);
    z-index: 1; animation: s3k-drop .6s cubic-bezier(.18,.7,.2,1) both;
  }
  /* wordmark sits on the banner; flex-centred so the slide transform can't fight centering */
  .s3k-wordmark {
    position: absolute; left: 0; right: 0; top: 26%; z-index: 3;
    display: flex; justify-content: center;
    animation: s3k-inR .55s ease-out .15s both;
  }
  .s3k-wordmark :global(svg) { width: clamp(280px, 46vw, 560px); height: auto;
    filter: drop-shadow(0 5px 0 rgba(14, 14, 16, .8)); }

  .s3k-row {
    position: absolute; left: 0; right: 0; top: 60%; z-index: 3;
    display: flex; gap: 28px; align-items: center; justify-content: center;
    animation: s3k-inR .55s ease-out .25s both;
  }
  .s3k-zone {
    font-family: var(--font-s3k-text); font-size: clamp(26px, 4.4vw, 56px);
    color: var(--ogf-yellow); -webkit-text-stroke: 2px var(--ogf-ink);
    paint-order: stroke fill; letter-spacing: 3px;
  }
  .s3k-ver { display: inline-flex; flex-direction: column; align-items: center;
    background: var(--ogf-yellow); border: 4px solid var(--ogf-ink); transform: rotate(-3deg);
    box-shadow: 4px 4px 0 rgba(14,14,16,.45); padding: 4px 14px; }
  .s3k-ver i { font: 900 10px var(--font-body); text-transform: uppercase; letter-spacing: 1px; color: var(--ogf-ink); font-style: normal; }
  .s3k-ver b { font: 700 18px var(--font-display); color: var(--ogf-ink); }

  .s3k-tagline {
    position: absolute; left: 0; right: 0; top: 74%; z-index: 3; text-align: center;
    font-family: var(--font-black); font-style: italic; font-size: clamp(18px, 3vw, 36px);
    color: #fff; -webkit-text-stroke: 2px var(--ogf-ink); paint-order: stroke fill;
    animation: s3k-inR .55s ease-out .32s both;
  }
  .s3k-ctas {
    position: absolute; left: 0; right: 0; top: 86%; z-index: 3;
    display: flex; gap: 16px; justify-content: center;
    animation: s3k-inUp .5s ease-out .42s both;
  }
  .s3k-btn { font: 900 clamp(15px,1.8vw,20px) var(--font-body); padding: 15px 30px;
    border: 4px solid var(--ogf-ink); border-radius: 8px; text-decoration: none;
    box-shadow: 4px 4px 0 rgba(14,14,16,.35); }
  .s3k-btn.p { background: var(--ogf-ink); color: #fff; }
  .s3k-btn.s { background: #fff; color: var(--ogf-ink); }

  @keyframes s3k-drop { from { transform: translateY(-180%); } to { transform: none; } }
  @keyframes s3k-inR  { from { transform: translateX(70vw); opacity: 0; } to { transform: none; opacity: 1; } }
  @keyframes s3k-inUp { from { transform: translateY(30px); opacity: 0; } to { transform: none; opacity: 1; } }

  @media (max-width: 640px) {
    .s3k-row { flex-direction: column; gap: 12px; }
    .s3k-ctas { flex-direction: column; align-items: center; }
  }
</style>
