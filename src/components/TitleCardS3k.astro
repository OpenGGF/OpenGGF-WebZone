---
// Sonic 3 & Knuckles title card — matched to the real thing: black background, a tall
// RED VERTICAL banner on the left (with a label at its base, Andes font), the zone
// name on the right in silver Andes with a grey offset shadow, "ZONE" below, and
// "ACT <n>" bottom-right. Our zone name is "OpenGGF".
interface Props { version: { label: string; isPre: boolean } | null; }
const { version } = Astro.props;
---
<section class="s3k" data-hero="s3k" aria-label="OpenGGF — Open-Source Sonic Engine">
  <div class="s3k-banner"><span class="s3k-banner-label">OPEN<br />SOURCE</span></div>

  <div class="s3k-content">
    <div class="s3k-name">OpenGGF</div>
    <div class="s3k-zone">ZONE</div>
    <div class="s3k-act"><span>ACT</span> <b>{version ? version.label : '1'}</b></div>
    <p class="s3k-tagline">Open-Source Sonic Engine</p>
    <div class="s3k-ctas">
      <a class="s3k-btn p" href="/#download">⬇ Download</a>
      <a class="s3k-btn s" href="/docs">Read the docs</a>
    </div>
  </div>
</section>

<style>
  .s3k { position: relative; width: 100%; height: clamp(480px, 84vh, 820px);
    overflow: hidden; background: #000; isolation: isolate; }

  /* tall red vertical banner on the left */
  .s3k-banner {
    position: absolute; left: 13%; top: 0; width: 16%; height: 82%;
    background: var(--ogf-red); border: 4px solid var(--ogf-ink); border-top: none;
    display: flex; align-items: flex-end; justify-content: center; padding-bottom: 14%;
    animation: s3k-drop .55s cubic-bezier(.18,.7,.2,1) both;
  }
  .s3k-banner-label { font-family: var(--font-s3k-text); color: #fff; font-size: clamp(13px, 1.5vw, 20px);
    letter-spacing: 1px; text-align: center; line-height: 1.15; }

  /* right-aligned content column */
  .s3k-content {
    position: absolute; right: 6%; top: 0; bottom: 0; width: min(64%, 760px);
    display: flex; flex-direction: column; align-items: flex-end; justify-content: center; gap: clamp(6px, 1.4vh, 16px);
    text-align: right;
  }
  .s3k-name {
    font-family: var(--font-s3k-text); color: #e9e9f2; font-size: clamp(40px, 7.5vw, 104px);
    line-height: .95; letter-spacing: 2px; text-shadow: 6px 7px 0 #4a4a55;
    animation: s3k-inR .55s ease-out .12s both;
  }
  .s3k-zone {
    font-family: var(--font-s3k-text); color: #e9e9f2; font-size: clamp(30px, 5.5vw, 76px);
    line-height: 1; letter-spacing: 6px; text-shadow: 5px 6px 0 #4a4a55;
    animation: s3k-inR .55s ease-out .22s both;
  }
  .s3k-act {
    font-family: var(--font-s3k-text); color: #fff; font-size: clamp(16px, 2vw, 26px);
    animation: s3k-inR .55s ease-out .3s both;
  }
  .s3k-act b { color: var(--ogf-yellow); -webkit-text-stroke: 1px #0006; }

  .s3k-tagline {
    margin-top: clamp(10px, 2vh, 22px);
    font-family: var(--font-black); font-style: italic; font-size: clamp(17px, 2.6vw, 32px);
    color: #fff; -webkit-text-stroke: 2px var(--ogf-ink); paint-order: stroke fill;
    animation: s3k-inR .55s ease-out .36s both;
  }
  .s3k-ctas { display: flex; gap: 14px; animation: s3k-inUp .5s ease-out .46s both; }
  .s3k-btn { font: 900 clamp(14px,1.7vw,19px) var(--font-body); padding: 14px 28px;
    border: 4px solid #fff; border-radius: 8px; text-decoration: none; box-shadow: 4px 4px 0 rgba(0,0,0,.5); }
  .s3k-btn.p { background: var(--ogf-yellow); color: var(--ogf-ink); border-color: var(--ogf-ink); }
  .s3k-btn.s { background: #111; color: #fff; }

  @keyframes s3k-drop { from { transform: translateY(-120%); } to { transform: none; } }
  @keyframes s3k-inR  { from { transform: translateX(60vw); opacity: 0; } to { transform: none; opacity: 1; } }
  @keyframes s3k-inUp { from { transform: translateY(30px); opacity: 0; } to { transform: none; opacity: 1; } }

  @media (max-width: 640px) {
    .s3k-banner { left: 4%; width: 22%; }
    .s3k-content { width: 70%; }
    .s3k-ctas { flex-direction: column; align-items: flex-end; }
  }
</style>
