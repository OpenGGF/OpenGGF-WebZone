---
interface Props { color?: string; overlap?: string; }
// Pale page-coloured zig teeth that OVERLAY the bottom of the hero, biting UP into
// the yellow/red. The element is pulled up by `overlap` so its peaks (clip y=0)
// poke into the hero; the yellow/red shows in the notches; below it the page
// continues seamlessly. 13 teeth to match the hero's red pane.
const { color = 'var(--ogf-paper)', overlap = '26px' } = Astro.props;
const clip = 'polygon(0% 100%,100% 100%,100% 55%,96.15% 0%,92.31% 55%,88.46% 0%,84.62% 55%,80.77% 0%,76.92% 55%,73.08% 0%,69.23% 55%,65.38% 0%,61.54% 55%,57.69% 0%,53.85% 55%,50% 0%,46.15% 55%,42.31% 0%,38.46% 55%,34.62% 0%,30.77% 55%,26.92% 0%,23.08% 55%,19.23% 0%,15.38% 55%,11.54% 0%,7.69% 55%,3.85% 0%,0% 55%)';
---
<div class="zig" style={`background:${color};clip-path:${clip};height:${overlap};margin-top:calc(-1 * ${overlap});`}></div>
<style>
  .zig { position: relative; z-index: 5; width: 100%; }
</style>
