---
// OpenGGF wordmark recreated from a font (Lilita One — chunky rounded mascot style)
// with the title-card layered look: black border (widest stroke) → gold outline →
// blue two-tone gradient fill. Pure SVG: crisp + smooth at any size, tiny payload.
import '@fontsource/lilita-one';
---
<svg class="ggf" viewBox="0 0 640 170" role="img" aria-label="OpenGGF" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="ggf-fill" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#8aa0f3" />
      <stop offset="46%" stop-color="#3a5ad9" />
      <stop offset="47%" stop-color="#20309f" />
      <stop offset="100%" stop-color="#182a86" />
    </linearGradient>
  </defs>
  <g font-family="'Lilita One', system-ui, sans-serif" font-size="128"
     text-anchor="middle" stroke-linejoin="round" paint-order="stroke">
    <text x="320" y="124" fill="none" stroke="#0E0E10" stroke-width="21">OpenGGF</text>
    <text x="320" y="124" fill="none" stroke="#FFD81F" stroke-width="11">OpenGGF</text>
    <text x="320" y="124" fill="url(#ggf-fill)">OpenGGF</text>
  </g>
</svg>
<style>
  .ggf { display: block; width: 100%; height: auto; overflow: visible; }
</style>
